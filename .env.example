# Sorro Brew Landing Page - Environment Configuration
# Copy this file to .env and update with your values

# Deployment Configuration
NODE_ENV=production
SITE_URL=https://sorrobrew.com

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=
HOTJAR_ID=

# API Keys (if needed for zip code processing)
WEATHER_API_KEY=
LOCATION_API_KEY=

# Performance Configuration
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CDN_URL=

# Earth Modern Design Configuration
PRIMARY_COLOR=#271310
SECONDARY_COLOR=#735c00
SURFACE_COLOR=#fefccf
ACCENT_COLOR=#ffdad4

# Build Optimization
MINIFY_HTML=true
OPTIMIZE_IMAGES=true
GENERATE_SITEMAP=true
